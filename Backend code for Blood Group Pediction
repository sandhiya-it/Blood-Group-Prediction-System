from tensorflow.keras.models import load_model
model = load_model("blood_group_model.h5")
def predict_image(image_path):
    img = cv2.imread(image_path)
    img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
    img_resized = cv2.resize(img, (128,128))
    img_resized = img_resized / 255.0
    img_resized = np.reshape(img_resized, (1,128,128,3))
    prediction = model.predict(img_resized)[0]
    classes = ['A+', 'A-', 'B+', 'B-', 'AB+', 'AB-', 'O+', 'O-']
    result = classes[np.argmax(prediction)]
    confidence = np.max(prediction)
    print("Predicted Blood Group:", result)
    print("Confidence:", confidence)
    plt.imshow(img_rgb)
    plt.title(f"Predicted: {result} ({confidence:.2f})")
    plt.axis('off')
    plt.show()
    print("Prediction Results:")
    for i, cls in enumerate(classes):
        print(f"{cls}: {float(prediction[i]):.2f}")
